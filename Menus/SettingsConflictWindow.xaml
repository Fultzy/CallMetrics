<Window x:Class="CallMetrics.Menus.SettingsConflictWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CallMetrics.Menus"
        xmlns:l="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:controls="clr-namespace:CallMetrics.Controls"
        mc:Ignorable="d" WindowStyle="None" AllowsTransparency="True"
        Title="SettingsConflictWindow" Width="400" Height="400" Background="Transparent">
    <Grid MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Border Background="#FF373737" BorderThickness="1" BorderBrush="Black" CornerRadius="4"/>

        <StackPanel>
            <Label Content="New Settings File Detected" FontSize="24" FontWeight="Bold" Foreground="White" Padding="30,0,0,0" VerticalAlignment="Top" Margin="5,10,5,0" HorizontalAlignment="Left"/>
            
            <TextBlock Text="Would you like to import the new settings?" FontSize="16" Foreground="#FFB9B9B9" Padding="30,30,30,0" VerticalAlignment="Top" Margin="5" HorizontalAlignment="Left" TextWrapping="Wrap"/>

            <TextBlock Text="Warning: The selected settings will overwrite the other!" FontSize="14" Foreground="#FFFF3B1C" Padding="30,0,30,10" VerticalAlignment="Top" Margin="5" HorizontalAlignment="Left" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Border Height="180" Width="145" Background="#FF464646" BorderThickness="4" BorderBrush="DimGray" CornerRadius="4" Margin="0,0,45,0">
                    <StackPanel>
                        <Label Content="Current Setting" FontSize="12" FontWeight="Bold" Foreground="White" Padding="10,5,10,5" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CurrentLastSavedText" Text="Last Saved: 3/19/2026 12:35:03 PM" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CurrentVersionText" Text="Version: v1.2.3.2" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CurrentRepCountText" Text="Aliases: 0" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="CurrentTeamCountText" Text="Teams: 0" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
                <Border Height="180" Width="145" Background="#FF3E463E" BorderThickness="4" BorderBrush="#FF5E735E" CornerRadius="4">
                    <StackPanel>
                        <Label Content="New Setting" FontSize="14" FontWeight="Bold" Foreground="White" Padding="10,5,10,5" VerticalAlignment="Top" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="NewLastSavedText" Text="Last Saved: 12/23/2025 12:35:03 AM" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="NewVersionText" Text="Version: OLD" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="NewRepCountText" Text="Aliases: 108" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock x:Name="NewTeamCountText" Text="Teams: 20" FontSize="12" Foreground="#FFEDEDED" Padding="5" VerticalAlignment="Center" HorizontalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>


        <StackPanel Margin="30,10,30,10" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Bottom">
            <Button Content="Use Current" FontSize="16" Padding="10" VerticalAlignment="Top" HorizontalAlignment="Left" Width="150" Click="KeepCurrentButton_Click" Foreground="White" Height="45" Margin="0,0,40,0"/>
            <Button Content="Use New" FontSize="16" Padding="10" VerticalAlignment="Top" Width="150" Click="ApplyNewButton_Click" Foreground="White" Height="45"/>
        </StackPanel>

    </Grid>
</Window>
